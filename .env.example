# Helius API key for token holder snapshots
HELIUS_API_KEY=your_helius_api_key

# Solana token mint address (pump.fun coin)
TOKEN_MINT=your_token_mint_address

# Solana RPC URL (Helius mainnet recommended)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key

# Base58-encoded secret key for the reward wallet (funds distributions)
REWARD_WALLET_SECRET=your_reward_wallet_secret_base58

# Secret for protecting the hourly cron endpoint
CRON_SECRET=generate_a_long_random_secret

# 32-byte hex key for encrypting secrets at rest (64 hex chars)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Reward threshold in USD before a gift card is purchased
REWARD_THRESHOLD_USD=100

# Amount of SOL required for wallet verification
VERIFY_AMOUNT_SOL=0.01

# Minimum token holding to be eligible for rewards
MIN_HOLDING=1

# Comma-separated wallet addresses to exclude from eligibility
EXCLUDE_ADDRESSES=

# Comma-separated gift card brands (playstation,xbox)
GIFT_CARD_BRANDS=playstation,xbox

# ---------- Bitrefill ----------
# Personal API: a single Bearer token from bitrefill.com > Account > Developers
BITREFILL_API_KEY=your_bitrefill_api_key
# Business API alternative (leave blank if using the personal key above)
BITREFILL_API_ID=
BITREFILL_API_SECRET=
# mock = fake codes (no API) | test = free Bitrefill test product | live = real money
BITREFILL_MODE=test
# live payment: solana = pay per claim from REWARD_WALLET_SECRET | balance = pre-funded Bitrefill USD
BITREFILL_PAYMENT_METHOD=solana
# Live-mode product ids per brand (run: npx tsx scripts/find-products.ts playstation)
BITREFILL_PRODUCT_PLAYSTATION=
BITREFILL_PRODUCT_XBOX=
# Optional override for the test product id
BITREFILL_TEST_PRODUCT=test-gift-card-code
# Optional base URL override
BITREFILL_BASE_URL=https://api.bitrefill.com/v2

# Optional Jupiter API key for higher rate limits
JUP_API_KEY=

# ---------- Pump.fun creator fees ----------
# Creator pubkey override (auto-detected from TOKEN_MINT bonding curve if unset)
PUMP_CREATOR_WALLET=
# Creator wallet secret for signing fee claims (required if creator != reward wallet)
PUMP_CREATOR_WALLET_SECRET=
# Min accumulated vault balance (lamports) before claiming (default 10000)
PUMP_MIN_CLAIM_LAMPORTS=10000

# Database (Docker: persisted in /data volume)
DATABASE_URL=file:/data/dev.db

# ---------- Test mode (dev only — set false in production) ----------
TEST_MODE=false
TEST_DISTRIBUTE_INTERVAL_MS=10000
